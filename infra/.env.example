# Скопируйте в infra/.env при развёртывании на сервере.

# Адрес машины, как её видит браузер пользователя (IP или домен, без порта).
# От него строятся: VITE_API_URL (:8000), presigned URL MinIO (:9000), CORS (:3000).
PUBLIC_HOST=localhost

# Учётные данные сервисов. Для публичного сервера ОБЯЗАТЕЛЬНО заменить
# (например: openssl rand -hex 24). Для локальной разработки можно не задавать.
POSTGRES_PASSWORD=slam
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
