# Скопируйте в .env для локальной разработки вне docker (значения по умолчанию
# совпадают с infra/docker-compose.yml, поэтому обычно .env не нужен).
DATABASE_URL=postgresql+psycopg://slam:slam@localhost:5432/slamcloude
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_RAW=raw-scans
S3_BUCKET_PROCESSED=processed-assets
